[Unit]
Description=Counter-Strike 1.6 Dedicated Server
After=network.target

[Service]
Type=simple
User=hlds
WorkingDirectory=/var/hlds/cs16
EnvironmentFile=/etc/hlds/cs16-server.conf
ExecStart=/var/hlds/cs16/hlds_run -game cstrike -norestart ${hlds_args}
KillSignal=SIGINT
Restart=on-failure
RestartSec=10
TimeoutStopSec=60

[Install]
WantedBy=multi-user.target
